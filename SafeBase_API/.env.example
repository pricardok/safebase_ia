# SafeBase API configuration

# Segurança JWT
SECRET_KEY=<>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Banco de dados SQL Server
# Conexão direta sem ODBC
DATABASE_URL=mssql+pymssql://<usuario>:<senha>@<host>/<database>

# Chave de API para autenticação via header
API_KEY_HEADER_NAME=X-API-Key
API_KEY_PREFIX=ApiKey

# Opcional: chave de API inicial para testes
DEFAULT_API_KEY=<>

# Chave mestre para criptografia das chaves IA
CRYPTO_MASTER_KEY=<>

# Tamanho máximo de lote de ingestão. Se não definido, usa 100.
MAX_INGESTION_BATCH_SIZE=100

# Normalizacao de payloads
NORMALIZATION_ENABLED=true
NORMALIZATION_INTERVAL_SECONDS=60
NORMALIZATION_BATCH_SIZE=100

# IA key failure handling
IA_KEY_FAILURE_THRESHOLD=3

# Logs de debug da IA
IA_DEBUG_LOGS_ENABLED=false

# Knowledge base (conhecimento_md)
KNOWLEDGE_MD_ENABLED=true
KNOWLEDGE_MD_MAX_ITEMS=5
KNOWLEDGE_MD_MAX_CHARS=1500
